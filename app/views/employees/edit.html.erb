<% content_for :title, "Editing employee" %>

<div class="container mt-4">
  <h1 class="text-light mb-4">Editing employee</h1>

  <div class="card bg-dark text-light border-secondary">
    <div class="card-body">
      <%= render "form", employee: @employee %>
    </div>
  </div>

  <div class="mt-4">
    <%= link_to "Show this employee", @employee, class: "btn btn-info me-2" %>
    <%= link_to "Back to employees", employees_path, class: "btn btn-secondary" %>
  </div>
</div>
